    },
    {
     "name": "Reservoir",
     "type": "StructBuffer"
    },
    {
     "name": "ReservoirOutput",
     "type": "StructBuffer"
    },
    {
     "name": "Output",
     "type": "Image2D"
    },
    {
     "name": "Velocity",
     "type": "Void"
    },
    {
     "name": "Depth",
