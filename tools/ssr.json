  {
   "id": "n4",
   "guid": "{74D309C3-371D-451E-877C-3EFCE94DFEB7}",
   "type": "Script",
   "position": [
    637,
    -1407
   ],
   "inputs": [
    {
     "name": "ViewPosition",
     "type": "Void"
    },
    {
     "name": "ViewNormal",
     "type": "Void"
    },
    {
     "name": "Projection",
     "type": "Matrix"
    },
    {
     "name": "DepthMap",
     "type": "Texture2D"
    },
    {
     "name": "DepthMapState",
     "type": "State"
    },
    {
     "name": "Random",
     "type": "Scalar1"
    }
   ],
   "outputs": [
    {
     "name": "Hit",
     "type": "Vector"
    }
   ],
   "domain": "Undefined",
   "properties": {
    "name": "Trace",
    "technique": "",
    "useRayTracing": false,
    "script": "\n// Screen-space reflection trace (perspective-correct DDA).\nvec3 P0 = $ViewPosition.xyz;\nvec3 N = normalize($ViewNormal.xyz);\nvec3 R = reflect(normalize(P0), N);\n\nconst float kMaxDistance = 70.0f;   // max view-space march distance\nconst int   kSteps = 64;            // screen-space march samples\nconst int   kRefine = 4;            // binary-search refinement iterations\nconst float kBias = 0.05f;           // depth bias to avoid self-intersection (view units)\nconst float kThickness = 0.1f;      // max depth-behind accepted as a hit (view units)\nconst float kZMin = 0.05f;          // keep the ray in front of the camera\n\n// March end point in view space, clamped to stay in front of the near plane.\nvec3 P1 = P0 + R * kMaxDistance;\nif (P1.z < kZMin)\n\tP1 = mix(P0, P1, (kZMin - P0.z) / (P1.z - P0.z));\n\n// Project the segment to screen UV; interpolate UV linearly and 1/z\n// perspective-correctly in screen space.\nvec4 c0 = $Projection * vec4(P0, 1.0f);\nvec4 c1 = $Projection * vec4(P1, 1.0f);\nvec2 uv0 = (c0.xy / c0.w) * vec2(0.5f, -0.5f) + vec2(0.5f, 0.5f);\nvec2 uv1 = (c1.xy / c1.w) * vec2(0.5f, -0.5f) + vec2(0.5f, 0.5f);\nfloat iz0 = 1.0f / P0.z;\nfloat iz1 = 1.0f / P1.z;\n\nfloat jitter = $Random.x;\n\n$Hit = vec4(0.0f);\n\nbool prevBehind = false;\nfloat prevJ = 0.0f;\nfor (int i = 1; i <= kSteps; ++i)\n{\n\tfloat j = (float(i) - 0.5f + jitter) / float(kSteps);\n\tvec2 uv = mix(uv0, uv1, j);\n\tif (uv.x < 0.0f || uv.x > 1.0f || uv.y < 0.0f || uv.y > 1.0f)\n\t\tbreak; // ray left the screen.\n\n\tfloat rayZ = 1.0f / mix(iz0, iz1, j);\n\tfloat sceneZ = texture(sampler2D($DepthMap, $DepthMapState), uv).x;\n\tbool behind = (rayZ - sceneZ) > kBias;\n\n\t// First transition from in-front to behind the surface is a candidate hit.\n\tif (behind && !prevBehind && i > 1)\n\t{\n\t\tfloat a = prevJ;\n\t\tfloat b = j;\n\t\tfor (int k = 0; k < kRefine; ++k)\n\t\t{\n\t\t\tfloat m = 0.5f * (a + b);\n\t\t\tfloat rzm = 1.0f / mix(iz0, iz1, m);\n\t\t\tfloat szm = texture(sampler2D($DepthMap, $DepthMapState), mix(uv0, uv1, m)).x;\n\t\t\tif (rzm - szm > kBias) b = m; else a = m;\n\t\t}\n\t\tvec2 fuv = mix(uv0, uv1, b);\n\t\tfloat fdiff = (1.0f / mix(iz0, iz1, b)) - texture(sampler2D($DepthMap, $DepthMapState), fuv).x;\n\t\tif (fdiff <= kThickness)\n\t\t{\n\t\t\t// Edge attenuation.\n\t\t\tfloat att = fuv.x * (1.0f - fuv.x) * fuv.y * (1.0f - fuv.y);\n\t\t\tatt = clamp(att * 256.0f, 0.0f, 1.0f);\n\t\t\t$Hit = vec4(fuv, att, 1.0f);\n\t\t\tbreak;\n\t\t}\n\t\t// Otherwise the ray is occluded by foreground geometry; keep marching.\n\t}\n\n\tprevBehind = behind;\n\tprevJ = j;\n}\n"
   }
  },
